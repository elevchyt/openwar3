+// LSB-first bit input stream (mirrors StormLib's TInputStream).
+class TInputStream {
+  constructor(buf) { this.buf = buf; this.pos = 0; this.bitBuffer = 0; this.bitCount = 0; }
+  get1Bit() {
+    if (this.bitCount === 0) {
+      if (this.pos >= this.buf.length) return -1;
+      this.bitBuffer = this.buf[this.pos++];
+      this.bitCount = 8;
+    }
+    const v = this.bitBuffer & 1;
+    this.bitBuffer >>>= 1;
+    this.bitCount--;
+    return v;
+  }
+  get8Bits() {
+    if (this.bitCount < 8) {
+      if (this.pos >= this.buf.length) return -1;
+      this.bitBuffer |= this.buf[this.pos++] << this.bitCount;
+      this.bitCount += 8;
+    }
+    const v = this.bitBuffer & 0xFF;
+    this.bitBuffer >>>= 8;
