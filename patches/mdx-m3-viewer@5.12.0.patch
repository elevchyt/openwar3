+    p2.prev = p1.next.prev;
+    p1.next.prev = p2;
+    p1.next = p2;
+  }
+  removeItem(it) {
+    if (it.next !== null) {
+      it.prev.next = it.next;
+      it.next.prev = it.prev;
+      it.next = it.prev = null;
+    }
+  }
+  insertItem(it, insertAfter, insertPoint) {
+    this.removeItem(it);
+    if (insertPoint == null) insertPoint = this.head;
+    if (insertAfter) this.linkTwoItems(insertPoint, it);
+    else this.linkTwoItems(insertPoint.prev, it);
