+const PACKED = "";
+const DataDistributions = [];
+for (let t = 0; t < 9; t++) {
+  const a = new Uint8Array(256);
+  for (let i = 0; i < 256; i++) a[i] = parseInt(PACKED.substr((t * 256 + i) * 2, 2), 16);
+  DataDistributions.push(a);
