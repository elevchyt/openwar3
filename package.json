{
  "name": "openwar3",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-first, asset-compatible re-creation of the Warcraft III engine (TypeScript). Ships zero Blizzard assets.",
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "events": "^3.3.0",
    "gl-matrix": "^3.4.3",
    "mdx-m3-viewer": "^5.12.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "patchedDependencies": {
      "mdx-m3-viewer@5.12.0": "patches/mdx-m3-viewer@5.12.0.patch"
    }
  }
}
